# R
.Rproj.user
.Rhistory
.RData
.Ruserdata
.Renviron
.httr-oauth

# Sistema
.DS_Store

# Datos CRUDOS del scraping: NO se versionan (pesados, regenerables)
scraping/datos/*
!scraping/datos/.gitkeep

# Logs del scraping
scraping/logs/*
!scraping/logs/.gitkeep

# Base tokenizada a nivel de palabra: pesada y regenerable; la app NO la usa.
datos/cgr_palabras.parquet

# Muestra externa de noticias (CSV grande, p. ej. la de 10.000 de prensa_chile):
# no se versiona; solo las noticias CGR filtradas que entran a cgr_datos.parquet.
datos/*.csv

# El resto de datos/ (procesados finales y livianos) SÍ se versiona, para que
# la app funcione sin reprocesar:
#   cgr_datos.parquet, cgr_palabras_semana.parquet, cgr_noticias_semana.parquet,
#   cgr_tfidf_fuente.parquet, cgr_metricas.rds, cgr_terminos.R, stopwords_es.txt

# Chromote / Chrome
chrome-debug.log
